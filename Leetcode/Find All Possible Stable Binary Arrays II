#include <vector>

using namespace std;

class Solution {
public:
    int numberOfStableArrays(int zero, int one, int limit) {
        long long MOD = 1e9 + 7;
        // dp[i][j][0] = stable arrays with i zeros, j ones, ending in 0
        // dp[i][j][1] = stable arrays with i zeros, j ones, ending in 1
        vector<vector<vector<long long>>> dp(zero + 1, vector<vector<long long>>(one + 1, vector<long long>(2, 0)));

        // Base cases: arrays with only 0s or only 1s
        for (int i = 0; i <= min(zero, limit); ++i) dp[i][0][0] = 1;
        for (int j = 0; j <= min(one, limit); ++j) dp[0][j][1] = 1;

        for (int i = 1; i <= zero; ++i) {
            for (int j = 1; j <= one; ++j) {
                // Ending with 0
                // We take all stable arrays (i-1, j) and append a 0.
                // If i > limit, we subtract arrays that had 'limit' zeros already.
                dp[i][j][0] = (dp[i - 1][j][0] + dp[i - 1][j][1]) % MOD;
                if (i > limit) {
                    // Subtract the case where we had (i-limit-1, j) and added (limit+1) zeros.
                    // The invalid case specifically comes from dp[i-limit-1][j][1]
                    dp[i][j][0] = (dp[i][j][0] - dp[i - limit - 1][j][1] + MOD) % MOD;
                }

                // Ending with 1
                dp[i][j][1] = (dp[i][j - 1][0] + dp[i][j - 1][1]) % MOD;
                if (j > limit) {
                    dp[i][j][1] = (dp[i][j][1] - dp[i][j - limit - 1][0] + MOD) % MOD;
                }
            }
        }

        return (dp[zero][one][0] + dp[zero][one][1]) % MOD;
    }
};