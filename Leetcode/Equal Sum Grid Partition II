#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    bool canRemove(vector<vector<int>>& grid, int target, int r1, int r2, int c1, int c2) {
        int rows = r2 - r1 + 1;
        int cols = c2 - c1 + 1;

        // Case 1: multi-row and multi-col → always safe
        if (rows > 1 && cols > 1) {
            for (int i = r1; i <= r2; i++) {
                for (int j = c1; j <= c2; j++) {
                    if (grid[i][j] == target) return true;
                }
            }
        }

        // Case 2: single row
        if (rows == 1) {
            for (int j = c1; j <= c2; j++) {
                if (grid[r1][j] == target) {
                    if (j == c1 || j == c2) return true; // edge only
                }
            }
        }

        // Case 3: single column
        if (cols == 1) {
            for (int i = r1; i <= r2; i++) {
                if (grid[i][c1] == target) {
                    if (i == r1 || i == r2) return true; // edge only
                }
            }
        }

        return false;
    }

    bool solve(vector<vector<int>>& grid) {
        int m = grid.size();
        int n = grid[0].size();

        long long total = 0;
        for (auto &row : grid)
            for (int x : row)
                total += x;

        // ---------- Horizontal Cuts ----------
        long long topSum = 0;
        for (int i = 0; i < m - 1; i++) {
            for (int j = 0; j < n; j++)
                topSum += grid[i][j];

            long long bottomSum = total - topSum;

            if (topSum == bottomSum) return true;

            long long diff = abs(topSum - bottomSum);

            if (topSum > bottomSum) {
                if (canRemove(grid, diff, 0, i, 0, n - 1)) return true;
            } else {
                if (canRemove(grid, diff, i + 1, m - 1, 0, n - 1)) return true;
            }
        }

        // ---------- Vertical Cuts ----------
        vector<long long> colSum(n, 0);
        for (int j = 0; j < n; j++)
            for (int i = 0; i < m; i++)
                colSum[j] += grid[i][j];

        long long leftSum = 0;
        for (int j = 0; j < n - 1; j++) {
            leftSum += colSum[j];
            long long rightSum = total - leftSum;

            if (leftSum == rightSum) return true;

            long long diff = abs(leftSum - rightSum);

            if (leftSum > rightSum) {
                if (canRemove(grid, diff, 0, m - 1, 0, j)) return true;
            } else {
                if (canRemove(grid, diff, 0, m - 1, j + 1, n - 1)) return true;
            }
        }

        return false;
    }

    bool canPartitionGrid(vector<vector<int>>& grid) {
        return solve(grid);
    }
};