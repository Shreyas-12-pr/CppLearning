#include <string>

using namespace std;

class Solution {
public:
    bool canBeEqual(string s1, string s2) {
        // Even indices: Check if {s1[0], s1[2]} matches {s2[0], s2[2]}
        bool evenMatch = (s1[0] == s2[0] && s1[2] == s2[2]) || 
                         (s1[0] == s2[2] && s1[2] == s2[0]);
        
        // Odd indices: Check if {s1[1], s1[3]} matches {s2[1], s2[3]}
        bool oddMatch = (s1[1] == s2[1] && s1[3] == s2[3]) || 
                        (s1[1] == s2[3] && s1[3] == s2[1]);
        
        return evenMatch && oddMatch;
    }
};