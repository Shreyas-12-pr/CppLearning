#include <vector>
#include <algorithm>

using namespace std;

class Solution {
public:
    vector<vector<int>> reverseSubmatrix(vector<vector<int>>& grid, int x, int y, int k) {
        // We iterate through the first half of the submatrix rows (k/2)
        for (int i = 0; i < k / 2; ++i) {
            // Swap elements in row (x + i) with elements in row (x + k - 1 - i)
            // but only for the columns within the submatrix (y to y + k - 1)
            for (int j = 0; j < k; ++j) {
                swap(grid[x + i][y + j], grid[x + k - 1 - i][y + j]);
            }
        }
        return grid;
    }
};