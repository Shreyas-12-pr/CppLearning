#include <iostream>
#include <vector>
#include <string>

using namespace std;

class Solution {
public:
    string generateString(string str1, string str2) {
        int n = str1.length();
        int m = str2.length();
        int L = n + m - 1;
        
        string word(L, '?');
        vector<bool> fixed(L, false);

        // Step 1: Fill all 'T' requirements
        for (int i = 0; i < n; ++i) {
            if (str1[i] == 'T') {
                for (int j = 0; j < m; ++j) {
                    if (word[i + j] != '?' && word[i + j] != str2[j]) {
                        return ""; // Contradiction between 'T's
                    }
                    word[i + j] = str2[j];
                    fixed[i + j] = true;
                }
            }
        }

        // Step 2: Fill remaining gaps with 'a' for lexicographical smallest
        for (int i = 0; i < L; ++i) {
            if (word[i] == '?') {
                word[i] = 'a';
            }
        }

        // Step 3: Verify and fix 'F' requirements
        for (int i = 0; i < n; ++i) {
            if (str1[i] == 'F') {
                // Check if it currently equals str2
                if (word.substr(i, m) == str2) {
                    bool fixed_an_issue = false;
                    // Try to change the rightmost possible character to the 
                    // smallest possible different character
                    for (int j = m - 1; j >= 0; --j) {
                        if (!fixed[i + j]) {
                            // Try changing to the next char ('a' -> 'b', etc.)
                            // but usually 'a' is what causes the match, so changing it to 'b' 
                            // or something else works. To keep it smallest, we only change 
                            // if it strictly equals the str2 character.
                            for (char c = 'b'; c <= 'z'; ++c) {
                                if (c != str2[j]) {
                                    word[i + j] = c;
                                    fixed_an_issue = true;
                                    break;
                                }
                            }
                            if (fixed_an_issue) break;
                        }
                    }
                    if (!fixed_an_issue) return ""; // No character could be changed
                }
            }
        }

        return word;
    }
};