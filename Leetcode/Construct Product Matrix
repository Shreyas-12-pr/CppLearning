#include <vector>

using namespace std;

class Solution {
public:
    vector<vector<int>> constructProductMatrix(vector<vector<int>>& grid) {
        int n = grid.size();
        int m = grid[0].size();
        const int MOD = 12345;
        
        vector<vector<int>> p(n, vector<int>(m));
        long long currentProduct = 1;

        // Step 1: Forward pass (Prefix Products)
        for (int i = 0; i < n; ++i) {
            for (int j = 0; j < m; ++j) {
                p[i][j] = currentProduct;
                // Update product with current element for the next iteration
                currentProduct = (currentProduct * (grid[i][j] % MOD)) % MOD;
            }
        }

        currentProduct = 1; // Reset for suffix pass

        // Step 2: Backward pass (Suffix Products)
        for (int i = n - 1; i >= 0; --i) {
            for (int j = m - 1; j >= 0; --j) {
                // Multiply current prefix product by the suffix product
                p[i][j] = (p[i][j] * currentProduct) % MOD;
                // Update suffix product with current element
                currentProduct = (currentProduct * (grid[i][j] % MOD)) % MOD;
            }
        }

        return p;
    }
};