#include <iostream>
#include <string>
#include <vector>

class Solution {
public:
    bool checkStrings(std::string s1, std::string s2) {
        int n = s1.length();
        // Frequency arrays for characters at even and odd positions
        std::vector<int> even_s1(26, 0), even_s2(26, 0);
        std::vector<int> odd_s1(26, 0), odd_s2(26, 0);

        for (int i = 0; i < n; ++i) {
            if (i % 2 == 0) {
                even_s1[s1[i] - 'a']++;
                even_s2[s2[i] - 'a']++;
            } else {
                odd_s1[s1[i] - 'a']++;
                odd_s2[s2[i] - 'a']++;
            }
        }

        // Check if even position characters and odd position characters match
        return (even_s1 == even_s2 && odd_s1 == odd_s2);
    }
};