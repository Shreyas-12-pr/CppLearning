#include <vector>
#include <string>

using namespace std;

class Solution {
public:
    string findTheString(vector<vector<int>>& lcp) {
        int n = lcp.size();
        string res(n, 0);
        char cur = 'a';

        // 1. Greedy construction of the string
        for (int i = 0; i < n; ++i) {
            if (res[i]) continue; // Already assigned
            if (cur > 'z') return ""; // Ran out of lowercase letters
            
            for (int j = i; j < n; ++j) {
                if (lcp[i][j] > 0) {
                    res[j] = cur;
                }
            }
            cur++;
        }
        
        // 2. Validation of the constructed string against the LCP matrix
        for (int i = n - 1; i >= 0; --i) {
            for (int j = n - 1; j >= 0; --j) {
                int expected = 0;
                if (res[i] == res[j]) {
                    // Recurrence: lcp[i][j] = 1 + lcp[i+1][j+1]
                    expected = (i + 1 < n && j + 1 < n) ? lcp[i + 1][j + 1] + 1 : 1;
                }
                
                if (lcp[i][j] != expected) {
                    return "";
                }
            }
        }

        return res;
    }
};